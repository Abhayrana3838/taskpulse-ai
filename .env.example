# OpenAI API Key (required for AI features)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# JWT Secret Key (generate random string)
# Generate: openssl rand -hex 32
SECRET_KEY=your-random-secret-key-here

# Database URL (Railway auto-provides this for PostgreSQL)
# Local: sqlite:///./taskpulse.db
# Railway: postgresql://user:pass@host:port/database
DATABASE_URL=sqlite:///./taskpulse.db

# CORS Origins (comma-separated)
# Use * for all origins (development only)
# Production: https://your-frontend.up.railway.app
CORS_ORIGINS=*

# Frontend API URL (for production build)
# Set this in Railway Static Site environment variables
VITE_API_URL=http://localhost:8000
